  "cors": "^2.8.5",
  "dotenv": "^16.3.1",
  "express": "^4.18.2",
  "validador express": "^7.0.1",
  "jsonwebtoken": "^9.0.2",
  "multer": "^1.4.5-lts.1",
  "mysql": "^3.6.5",
  "secuela": "^6.35.2"
 },
 "devDependencies": {
  "@types/jest": "^30.0.0",

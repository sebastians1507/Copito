{
 "nombre": "Backend de comercio electrónico",
 "versión": "1.0.0",
 "description": "Backend para sistema de comercio electrónico con Node.js, Express y Sequelize",
 "principal": "server.js",
 "guiones": {
  "inicio": "node server.js",
  "dev": "nodemon server.js",
  "init-db": "configuración del nodo/createDatabase.js",
  "reset-db": "configuración del nodo/resetDatabase.js",
  "sedd": "nodo -e \" require('./seeders/adminSeeder').runSeeders().then(() => proceso.exit(0)).catch((err) => { console.error(err): proceso.exit(1); }) \" ",
  "prueba": "jest --detectOpenHandles --forceExit",
  "texto:watch": "broma --watch",
  "prueba:cobertura": "jest --cobertura"
 },
 "palabras clave": [
  "comercio electrónico",
  "nodejs",
  "expresar",
  "secuelar",
  "jwt",
  "mysql"
 ],
 "autor": "Sebastin.an Sánchez",
 "licencia": "ISC",
